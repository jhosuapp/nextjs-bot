OPENAI_API_KEY=
# Modelo para la clasificación de intención del bot (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Máx. tokens de la respuesta del clasificador (default: 150)
MAX_TOKENS=150
# Usar GPT para clasificar; si es False o falta la API key, usa solo palabras clave
USE_GPT_ANALYZER=True
DATABASE_URL="mysql://user:password@localhost:3306/name_db"

# NOTE: use the legacy sendinblue hostname — algunos nodos regionales de Brevo
# presentan certs cuyas altnames solo incluyen *.sendinblue.com, no *.brevo.com.
BREVO_SMTP_HOST="smtp-relay.sendinblue.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER="dummy-login@smtp-brevo.com"
BREVO_SMTP_PASSWORD="dummy-master-password"
MAIL_FROM_EMAIL="no-reply@150porciento.ai"
MAIL_FROM_NAME="150%"